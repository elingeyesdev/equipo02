# Copia a .env y ajusta si cambias rutas o puerto:
#   cp .env.example .env

# Puerto HTTP del Explorer en el host (evita choque con otras apps en 8080)
PORT=8081

# Ruta absoluta o relativa al directorio donde ejecutas docker compose
EXPLORER_CONFIG_FILE_PATH=./config.json
EXPLORER_PROFILE_DIR_PATH=./connection-profile

# Carpeta organizations del test-network (CA). Debe coincidir con el volumen montado en /tmp/crypto
FABRIC_CRYPTO_PATH=../red-hyperledger/test-network/organizations
