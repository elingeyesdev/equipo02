# Configuración de Hyperledger Fabric (Basada en entregable 1.4)
PORT=3000

# Identidad de la Organización
MSPID=Org1MSP

# Rutas a los materiales criptográficos (ajustar si se mueve el repositorio)
# Estas rutas apuntan a la carpeta red-hyperledger/test-network/organizations/...
CERT_PATH=../red-hyperledger/test-network/organizations/peerOrganizations/org1.example.com/users/Admin@org1.example.com/msp/signcerts/cert.pem
KEY_PATH_DIR=../red-hyperledger/test-network/organizations/peerOrganizations/org1.example.com/users/Admin@org1.example.com/msp/keystore
TLS_CERT_PATH=../red-hyperledger/test-network/organizations/peerOrganizations/org1.example.com/peers/peer0.org1.example.com/tls/ca.crt

# Detalles de la Red
PEER_ENDPOINT=localhost:7051
PEER_HOST_ALIAS=peer0.org1.example.com
CHANNEL_NAME=clientes
CHAINCODE_NAME=cliente_cc
TOKEN_CHAINCODE_NAME=token_erc20

# Hito 2.5 — API administrativa de chaincode (cabecera X-Admin-Api-Key). Cambiar en producción.
ADMIN_API_KEY=cambiar-en-produccion

# Opcional: ruta absoluta o relativa al cwd del proceso para bitácora JSON Lines
# CHAINCODE_BITACORA_FILE=logs/bitacora-chaincode.log

# Opcional: JSON de políticas que sustituye al embebido (misma estructura que internal/chaincodepolicy/politicas_chaincode.json)
# CHAINCODE_POLITICAS_FILE=
