# Copiar a `.env` y rellenar valores. No commitear `.env` con secretos reales.

# --- API pública (hito 2.6): cabecera X-API-Key ---
# Cada variable define una API key y el rol asociado en el servidor.
API_KEY_ADMIN=
API_KEY_INTEGRADOR=
API_KEY_SOLO_LECTURA=

# --- Rutas /admin/... (sin mezclar con X-API-Key) ---
ADMIN_API_KEY=

# --- Servidor ---
PORT=3000

# --- Hyperledger Fabric (gateway) ---
MSPID=
CERT_PATH=
KEY_PATH_DIR=
TLS_CERT_PATH=
PEER_ENDPOINT=
PEER_HOST_ALIAS=
CHANNEL_NAME=

# Opcional: políticas chaincode (hito 2.5)
# CHAINCODE_POLITICAS_FILE=
